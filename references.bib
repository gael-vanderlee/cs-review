  shorttitle = {Vection Is the Main Contributor to Motion Sickness Induced by Visual Yaw Rotation},
  author = {Nooij, Suzanne A. E. and Pretto, Paolo and Oberfeld, Daniel and Hecht, Heiko and B{\"u}lthoff, Heinrich H.},
