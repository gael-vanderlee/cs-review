  urldate = {2025-07-02},
  abstract = {Cybersickness is a situation that may result from the overexpose to computer devices by a person. Symptoms associated with this sickness are dizziness, headache, nausea, or any kind of disoriented motion. Prediction of cybersickness is essential to avoid the aforementioned symptoms and subsequently secure people's health. In this work a Deep Embedded Self Organizing Map that is an unsupervised learning tool is jointly combined with an Auto-encoder implementing a clustering method. The Auto encoder is designed from EEGNET, which is a specialized CNN for EEG prediction, and is tailored to predict EEG based cybersickness. The proposed method is compared to KNN and SOM clustering methods and prediction accuracy was measured with the purity index and NMI. Test results give that KNN predicted cyberscikness by providing Purity equal to 0.9375 and NMI to 0.386519, while SOM had 0.9432 Purity and 0.403901 NMI. Lastly, DESOM provided the most efficient index values and more specifically: 0.96875 purity and 0.42561 NMI.},
  keywords = {Autoencoder,Brain modeling,Clustering methods,Cybersickness,EEG,Electroencephalography,Indexes,Self Organizing Map,Self-organizing feature maps,Tools,Unsupervised learning,Unsupervised-Learning},
  file = {/Users/gael/Zotero/storage/GRVMCMCS/Lee and Alamaniotis - 2020 - Unsupervised EEG Cybersickness Prediction with Deep Embedded Self Organizing Map.pdf}
}

