@article{yadavComprehensiveAssessmentBrain2020,
  title = {A Comprehensive Assessment of {{Brain Computer Interfaces}}: {{Recent}} Trends and Challenges},
  shorttitle = {A Comprehensive Assessment of {{Brain Computer Interfaces}}},
  author = {Yadav, Drishti and Yadav, Shilpee and Veer, Karan},
  year = {2020},
