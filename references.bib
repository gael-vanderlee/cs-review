@article{stanneyIdentifyingCausesSolutions2020,
  title = {Identifying {{Causes}} of and {{Solutions}} for {{Cybersickness}} in {{Immersive Technology}}: {{Reformulation}} of a {{Research}} and {{Development Agenda}}},
  shorttitle = {Identifying {{Causes}} of and {{Solutions}} for {{Cybersickness}} in {{Immersive Technology}}},
  author = {Stanney, Kay and Lawson, Ben D. and Rokers, Bas and Dennison, Mark and Fidopiastis, Cali and Stoffregen, Thomas and Weech, S{\'e}amas and Fulvio, Jacqueline M.},
  year = {2020},
