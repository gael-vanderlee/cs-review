  booktitle = {Proceedings of the 2020 {{CHI Conference}} on {{Human Factors}} in {{Computing Systems}}},
  author = {Ashtari, Narges and Bunt, Andrea and McGrenere, Joanna and Nebeling, Michael and Chilana, Parmit K.},
