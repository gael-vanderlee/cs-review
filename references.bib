  keywords = {AR/VR authoring,AR/VR design,AR/VR development,augmented reality,end-user development,virtual reality},
  annotation = {71 citations (Semantic Scholar/DOI) [2022-12-15]},
  file = {/Users/gael/Zotero/storage/4E7XK9LU/Ashtari et al. - 2020 - Creating Augmented and Virtual Reality Application.pdf}
}

