@article{casermanCybersicknessCurrentgenerationVirtual2021,
  title = {Cybersickness in Current-Generation Virtual Reality Head-Mounted Displays: Systematic Review and Outlook},
  shorttitle = {Cybersickness in Current-Generation Virtual Reality Head-Mounted Displays},
  author = {Caserman, Polona and {Garcia-Agundez}, Augusto and G{\'a}mez Zerban, Alvar and G{\"o}bel, Stefan},
  year = {2021},
  month = dec,
