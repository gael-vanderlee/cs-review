@article{hussainMitigatingCybersicknessVirtual2021,
  title = {Mitigating {{Cybersickness}} in {{Virtual Reality Systems}} through {{Foveated Depth-of-Field Blur}}},
  author = {Hussain, Razeen and Chessa, Manuela and Solari, Fabio},
  year = {2021},
