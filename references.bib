@article{liuExploringQuantitativeAssessment2024,
  title = {Exploring Quantitative Assessment of Cybersickness in Virtual Reality Using {{EEG}} Signals and a {{CNN-ECA-LSTM}} Network},
  author = {Liu, Mutian and Yang, Banghua and Xu, Mengdie and Zan, Peng and Chen, Luting and Xia, Xinxing},
  year = {2024},
