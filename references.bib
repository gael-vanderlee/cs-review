@inproceedings{khoirunnisaaChannelSelectionEEGBased2018,
  title = {Channel {{Selection}} of {{EEG-Based Cybersickness Recognition}} during {{Playing Video Game Using Correlation Feature Selection}} ({{CFS}})},
  booktitle = {2018 2nd {{International Conference}} on {{Biomedical Engineering}} ({{IBIOMED}})},
