@inproceedings{liRestingstateEEGVestibular2023,
  title = {Resting-State {{EEG}} in the {{Vestibular Region Can Predict Motion Sickness Induced}} by a {{Motion-Simulated}} in-Car {{VR Platform}}},
  booktitle = {2023 {{IEEE Symposium Series}} on {{Computational Intelligence}} ({{SSCI}})},
